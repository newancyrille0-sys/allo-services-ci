// This is your Prisma schema file for Allo Services CI
// Marketplace de mise en relation clients/prestataires en Côte d'Ivoire

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USER MODEL ====================

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  role         String   @default("CLIENT") // CLIENT, PROVIDER, ADMIN
  status       String   @default("PENDING_VERIFICATION") // ACTIVE, SUSPENDED, BANNED, PENDING_VERIFICATION
  fullName     String?
  avatarUrl    String?
  city         String?
  country      String   @default("Côte d'Ivoire")
  otpVerified  Boolean  @default(false)
  trustScore   Int      @default(0)
  emailVerified DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  provider             Provider?
  reservationsAsClient Reservation[] @relation("ClientReservations")
  reviews              Review[]      @relation("ClientReviews")
  messagesSent         Message[]     @relation("SentMessages")
  messagesReceived     Message[]     @relation("ReceivedMessages")
  payments             Payment[]
  notifications        Notification[]
  fraudLogs            FraudLog[]
  accounts             Account[]
  sessions             Session[]
  otpCodes             OTPCode[]
}

// ==================== PROVIDER MODEL ====================

model Provider {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName          String?
  description           String?
  categories            String   // JSON array of category IDs
  hourlyRate            Float?
  isVerified            Boolean  @default(false)
  kycStatus             String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  kycDocuments          String?  // JSON array of document URLs
  badgeVerified         Boolean  @default(false)
  totalReservations     Int      @default(0)
  totalReviews          Int      @default(0)
  averageRating         Float    @default(0)
  subscriptionStatus    String   @default("STARTER") // STARTER, STANDARD, PREMIUM
  subscriptionExpiresAt DateTime?
  providerTier          String   @default("GRATUIT") // GRATUIT, BASIC, PREMIUM, ELITE
  tierExpiresAt         DateTime?
  isActive              Boolean  @default(false)
  latitude              Float?
  longitude             Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  reservations Reservation[] @relation("ProviderReservations")
  reviews      Review[]      @relation("ProviderReviews")
  subscriptions Subscription[]
  publications  ProviderPublication[]
  lives         ProviderLive[]
}

// ==================== SERVICE MODEL ====================

model Service {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  iconUrl      String?
  parentId     String?
  parent       Service?  @relation("SubServices", fields: [parentId], references: [id])
  subServices  Service[] @relation("SubServices")
  isActive     Boolean   @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime  @default(now())

  // Relations
  reservations Reservation[]
}

// ==================== RESERVATION MODEL ====================

model Reservation {
  id            String   @id @default(cuid())
  clientId      String
  client        User     @relation("ClientReservations", fields: [clientId], references: [id])
  providerId    String
  provider      Provider @relation("ProviderReservations", fields: [providerId], references: [id])
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
  status        String   @default("PENDING") // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED, DISPUTED
  scheduledDate DateTime
  address       String
  city          String
  phoneContact  String?
  notes         String?
  priceTotal    Float
  paymentStatus String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  review   Review?
  messages Message[]
  payments Payment[] @relation("ReservationPayments")
}

// ==================== REVIEW MODEL ====================

model Review {
  id            String   @id @default(cuid())
  reservationId String   @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  clientId      String
  client        User     @relation("ClientReviews", fields: [clientId], references: [id])
  providerId    String
  provider      Provider @relation("ProviderReviews", fields: [providerId], references: [id])
  rating        Int      // 1-5
  comment       String?
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ==================== MESSAGE MODEL ====================

model Message {
  id            String   @id @default(cuid())
  senderId      String
  sender        User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId    String
  receiver      User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  content       String
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

// ==================== SUBSCRIPTION MODEL ====================

model Subscription {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  planName   String   // STARTER, STANDARD, PREMIUM
  amount     Float
  currency   String   @default("XOF")
  startDate  DateTime
  endDate    DateTime
  status     String   @default("active")
  paymentId  String?
  autoRenew  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ==================== PAYMENT MODEL ====================

model Payment {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  reservationId  String?
  reservation    Reservation? @relation("ReservationPayments", fields: [reservationId], references: [id])
  amount         Float
  currency       String   @default("XOF")
  paymentMethod  String   // orange_money, mtn_money, wave, moov, card
  providerName   String?
  transactionId  String   @unique
  status         String   @default("pending")
  metadata       String?  // JSON
  createdAt      DateTime @default(now())
}

// ==================== NOTIFICATION MODEL ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // reservation, payment, system, promo
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
}

// ==================== FRAUD LOG MODEL ====================

model FraudLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  eventType  String
  severity   String   @default("low") // low, medium, high, critical
  ipAddress  String?
  description String?
  metadata   String?  // JSON
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ==================== NEXTAUTH MODELS ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== OTP CODE MODEL ====================

model OTPCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([phone, code])
}

// ==================== PROVIDER PUBLICATION MODEL ====================

model ProviderPublication {
  id                String   @id @default(cuid())
  providerId        String
  provider          Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  type              String   // photo, video
  mediaUrl          String
  thumbnailUrl      String?
  caption           String?
  servicePrice      Float?
  serviceDescription String?
  expiresAt         DateTime?
  viewCount         Int      @default(0)
  likeCount         Int      @default(0)
  commentCount      Int      @default(0)
  shareCount        Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  likes     PublicationLike[]
  comments  PublicationComment[]
  bookmarks PublicationBookmark[]
  views     PublicationView[]

  @@index([providerId])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}

// ==================== PROVIDER LIVE MODEL ====================

model ProviderLive {
  id           String   @id @default(cuid())
  providerId   String
  provider     Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  thumbnailUrl String?
  streamUrl    String?
  status       String   @default("scheduled") // scheduled, live, ended
  viewerCount  Int      @default(0)
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  likes    LiveLike[]
  comments LiveComment[]

  @@index([providerId])
  @@index([status])
}

// ==================== PUBLICATION INTERACTIONS ====================

model PublicationLike {
  id           String   @id @default(cuid())
  publicationId String
  publication  ProviderPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  userId       String
  createdAt    DateTime @default(now())

  @@unique([publicationId, userId])
  @@index([publicationId])
  @@index([userId])
}

model PublicationComment {
  id           String   @id @default(cuid())
  publicationId String
  publication  ProviderPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  userId       String
  content      String
  likeCount    Int      @default(0)
  parentId     String?
  parent       PublicationComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies      PublicationComment[] @relation("CommentReplies")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([publicationId])
  @@index([userId])
}

model PublicationBookmark {
  id           String   @id @default(cuid())
  publicationId String
  publication  ProviderPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  userId       String
  createdAt    DateTime @default(now())

  @@unique([publicationId, userId])
  @@index([userId])
}

model PublicationView {
  id           String   @id @default(cuid())
  publicationId String
  publication  ProviderPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  userId       String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([publicationId])
}

// ==================== LIVE INTERACTIONS ====================

model LiveLike {
  id        String   @id @default(cuid())
  liveId    String
  live      ProviderLive @relation(fields: [liveId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([liveId, userId])
  @@index([liveId])
}

model LiveComment {
  id        String   @id @default(cuid())
  liveId    String
  live      ProviderLive @relation(fields: [liveId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([liveId])
}

// ==================== USER FOLLOWS ====================

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ==================== ADMIN MODELS ====================

model Admin {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  fullName         String
  phone            String?
  role             String   @default("SUPPORT") // SUPER_ADMIN, ADMIN_SENIOR, ADMIN_MODERATOR, SUPPORT
  status           String   @default("ACTIVE") // ACTIVE, SUSPENDED, DEACTIVATED
  avatarUrl        String?
  permissions      String?
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      String?
  createdBy        Admin?   @relation("AdminCreator", fields: [createdById], references: [id])
  createdAdmins    Admin[]  @relation("AdminCreator")
  sessions         AdminSession[]

  @@index([email])
  @@index([role])
  @@index([status])
}

model AdminSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  adminId      String
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([sessionToken])
}

// ==================== PARTNER MODEL ====================

model Partner {
  id                  String   @id @default(cuid())
  name                String
  logoUrl             String
  websiteUrl          String?
  description         String?
  displayOrder        Int      @default(0)
  isActive            Boolean  @default(true)
  showInNotification  Boolean  @default(false)
  notificationMessage String?
  notificationStartAt DateTime?
  showOnHome          Boolean  @default(true)
  showOnPublicite     Boolean  @default(true)
  showOnDashboard     Boolean  @default(true)
  startDate           DateTime?
  endDate             DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive])
  @@index([showOnHome])
  @@index([showOnPublicite])
  @@index([showOnDashboard])
}

// ==================== ADMIN IMAGE MODEL ====================

model AdminImage {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  title     String?
  altText   String?
  category  String?
  createdAt DateTime @default(now())

  @@index([category])
}

// ==================== INSURANCE CLAIM MODEL ====================

model InsuranceClaim {
  id             String   @id @default(cuid())
  reservationId  String   @unique
  clientId       String
  providerId     String
  reason         String   // no_show, incomplete, poor_quality, damage
  description    String
  evidenceUrls   String?  // JSON array of image URLs
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED, RESOLVED
  resolution     String?  // agents_sent, refund, rejected
  resolvedAt     DateTime?
  resolvedBy     String?  // Admin ID
  agentsAssigned String?  // JSON array of assigned agent provider IDs
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
}

// ==================== LOYALTY & CASHBACK MODELS ====================

model LoyaltyPoints {
  id           String   @id @default(cuid())
  userId       String   @unique
  totalPoints  Int      @default(0)
  usedPoints   Int      @default(0)
  expiredPoints Int     @default(0)
  level        String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions LoyaltyTransaction[]

  @@index([userId])
  @@index([level])
}

model LoyaltyTransaction {
  id             String   @id @default(cuid())
  loyaltyPointsId String
  loyaltyPoints   LoyaltyPoints @relation(fields: [loyaltyPointsId], references: [id], onDelete: Cascade)
  points         Int
  type           String   // EARN, USE, EXPIRE, BONUS
  source         String   // reservation, referral, bonus, redemption
  sourceId       String?  // Related reservation/referral ID
  description    String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())

  @@index([loyaltyPointsId])
  @@index([type])
  @@index([source])
}

model Cashback {
  id             String   @id @default(cuid())
  userId         String
  reservationId  String?
  amount         Float
  percentage     Float
  status         String   @default("PENDING") // PENDING, AVAILABLE, USED, EXPIRED
  expiresAt      DateTime?
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// ==================== ANTI-LEAKAGE MODELS ====================

model ContactDetectionLog {
  id             String   @id @default(cuid())
  senderId       String
  receiverId     String
  reservationId  String?
  detectedType   String   // phone, email, address, external_app
  detectedValue  String?  // Hashed/masked value
  messageSnippet String?
  action         String   // warning_sent, blocked, flagged
  createdAt      DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([detectedType])
  @@index([createdAt])
}

model UserWarning {
  id           String   @id @default(cuid())
  userId       String
  type         String   // contact_leak, fraud_attempt, policy_violation
  reason       String
  reservationId String?
  metadata     String?  // JSON
  isResolved   Boolean  @default(false)
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([isResolved])
}

// ==================== PHONE MASKING MODEL ====================

model PhoneMasking {
  id            String   @id @default(cuid())
  reservationId String   @unique
  realPhone     String   // Encrypted
  maskedPhone   String   @unique
  providerId    String
  clientId      String
  expiresAt     DateTime
  callCount     Int      @default(0)
  smsCount      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([reservationId])
  @@index([maskedPhone])
  @@index([isActive])
}

// ==================== PASSWORD RESET TOKEN ====================

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ==================== RATE LIMIT ====================

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(1)
  resetAt   DateTime
  createdAt DateTime @default(now())

  @@index([key])
  @@index([resetAt])
}

// ==================== SYSTEM SETTINGS ====================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String?
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
}

// ==================== REFERRAL MODEL ====================

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String
  code         String
  status       String   @default("PENDING") // PENDING, COMPLETED, REWARDED
  rewardPoints Int      @default(0)
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@index([code])
}
