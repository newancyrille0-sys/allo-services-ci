# ==================== DATABASE ====================
# Supabase PostgreSQL (Production)
# Replace with your Supabase project credentials
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ==================== SUPABASE ====================
# Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"

# Anon Key (public, safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service Role Key (for server-side operations - KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ==================== NEXTAUTH ====================
# Generate a new secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key"

# Your application URL
NEXTAUTH_URL="http://localhost:3000"

# ==================== GOOGLE OAUTH ====================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==================== APP CONFIG ====================
# Application Environment
NODE_ENV="development"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API URL
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ==================== MOBILE MONEY (Côte d'Ivoire) ====================
# Orange Money API
ORANGE_MONEY_API_KEY="your-orange-api-key"
ORANGE_MONEY_MERCHANT_ID="your-orange-merchant-id"
ORANGE_MONEY_SECRET="your-orange-secret"

# Wave API
WAVE_API_KEY="your-wave-api-key"
WAVE_WEBHOOK_SECRET="your-wave-webhook-secret"

# MTN Mobile Money API
MTN_MONEY_API_KEY="your-mtn-api-key"
MTN_MONEY_MERCHANT_ID="your-mtn-merchant-id"
MTN_MONEY_SECRET="your-mtn-secret"

# Moov Money API
MOOV_MONEY_API_KEY="your-moov-api-key"
MOOV_MONEY_MERCHANT_ID="your-moov-merchant-id"

# ==================== SMS NOTIFICATIONS ====================
# Yellika SMS API (Côte d'Ivoire) - OAuth2.0
YELIKA_API_KEY="your-yellika-api-key"
YELIKA_SENDER_ID="ALLOSERVICES"
YELIKA_API_URL="https://panel.yellikasms.com/api/v3/sms/send"

# ==================== EMAIL ====================
# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# ==================== CLOUDINARY (Images) ====================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ==================== TWILIO (VoIP - Optional) ====================
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="+2250700000000"
